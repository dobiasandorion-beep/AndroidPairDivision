<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MyAndroidApp.SettingsPage"
             Title="設定"
             BackgroundColor="#F5F5F5">

    <Grid>
        <!-- メイン設定画面 -->
        <ScrollView>
            <VerticalStackLayout Spacing="20" Padding="20">
                <Label Text="アプリ設定" FontSize="24" FontAttributes="Bold" HorizontalOptions="Center" TextColor="#333333" />

                <!-- 組み合わせ設定 -->
                <Frame Padding="15" BorderColor="#E0E0E0" CornerRadius="8" HasShadow="False" BackgroundColor="White">
                    <VerticalStackLayout Spacing="10">
                        <Label Text="組み合わせ設定" FontSize="16" FontAttributes="Bold" TextColor="#333333" />
                        <Label Text="試合のペアリングに関する詳細設定を行います。" FontSize="12" TextColor="#888888" />
                        <Button Text="組み合わせ条件を設定する" 
                                Clicked="OnOpenMatchSettingsClicked" 
                                BackgroundColor="#2196F3" 
                                TextColor="White" 
                                CornerRadius="8" 
                                HeightRequest="45"
                                Margin="0,10,0,0"/>
                    </VerticalStackLayout>
                </Frame>

                <!-- 試合設定 -->
                <Frame Padding="15" BorderColor="#E0E0E0" CornerRadius="8" HasShadow="False" BackgroundColor="White">
                    <VerticalStackLayout Spacing="15">
                        <Label Text="試合設定" FontSize="16" FontAttributes="Bold" TextColor="#333333" />
                        
                        <Grid ColumnDefinitions="*, Auto" RowDefinitions="Auto, Auto, Auto" RowSpacing="10">
                            <!-- コート数 -->
                            <Label Grid.Row="0" Grid.Column="0" Text="コート数" VerticalOptions="Center" TextColor="#333333" />
                            <HorizontalStackLayout Grid.Row="0" Grid.Column="1" Spacing="5">
                                <Picker x:Name="CourtCountPicker" WidthRequest="90" TextColor="#333333" BackgroundColor="#F5F5F5" SelectedIndexChanged="OnSettingValueChanged">
                                    <Picker.ItemsSource>
                                        <x:Array Type="{x:Type x:String}">
                                            <x:String>1</x:String><x:String>2</x:String><x:String>3</x:String><x:String>4</x:String>
                                            <x:String>5</x:String><x:String>6</x:String><x:String>7</x:String><x:String>8</x:String>
                                        </x:Array>
                                    </Picker.ItemsSource>
                                </Picker>
                                <Label Text="面" VerticalOptions="Center" TextColor="#333333" />
                            </HorizontalStackLayout>

                            <!-- コール回数 -->
                            <Label Grid.Row="1" Grid.Column="0" Text="コール回数" VerticalOptions="Center" TextColor="#333333" />
                            <HorizontalStackLayout Grid.Row="1" Grid.Column="1" Spacing="5">
                                <Picker x:Name="CallCountPicker" WidthRequest="90" TextColor="#333333" BackgroundColor="#F5F5F5" SelectedIndexChanged="OnSettingValueChanged">
                                    <Picker.ItemsSource>
                                        <x:Array Type="{x:Type x:String}">
                                            <x:String>0</x:String><x:String>1</x:String><x:String>2</x:String><x:String>3</x:String>
                                            <x:String>4</x:String><x:String>5</x:String><x:String>6</x:String><x:String>7</x:String>
                                            <x:String>8</x:String><x:String>9</x:String><x:String>10</x:String>
                                        </x:Array>
                                    </Picker.ItemsSource>
                                </Picker>
                                <Label Text="回" VerticalOptions="Center" TextColor="#333333" />
                            </HorizontalStackLayout>

                            <!-- 試合時間 -->
                            <Label Grid.Row="2" Grid.Column="0" Text="試合時間" VerticalOptions="Center" TextColor="#333333" />
                            <Picker x:Name="MatchTimePicker" Grid.Row="2" Grid.Column="1" WidthRequest="100" TextColor="#333333" BackgroundColor="#F5F5F5" SelectedIndexChanged="OnSettingValueChanged">
                                <Picker.ItemsSource>
                                    <x:Array Type="{x:Type x:String}">
                                        <x:String>無制限</x:String>
                                        <x:String>1 分</x:String><x:String>2 分</x:String><x:String>3 分</x:String><x:String>4 分</x:String>
                                        <x:String>5 分</x:String><x:String>6 分</x:String><x:String>7 分</x:String><x:String>8 分</x:String>
                                        <x:String>9 分</x:String><x:String>10 分</x:String><x:String>11 分</x:String><x:String>12 分</x:String>
                                        <x:String>13 分</x:String><x:String>14 分</x:String><x:String>15 分</x:String><x:String>16 分</x:String>
                                        <x:String>17 分</x:String><x:String>18 分</x:String><x:String>19 分</x:String><x:String>20 分</x:String>
                                        <x:String>21 分</x:String><x:String>22 分</x:String><x:String>23 分</x:String><x:String>24 分</x:String>
                                        <x:String>25 分</x:String><x:String>26 分</x:String><x:String>27 分</x:String><x:String>28 分</x:String>
                                        <x:String>29 分</x:String><x:String>30 分</x:String>
                                    </x:Array>
                                </Picker.ItemsSource>
                            </Picker>
                        </Grid>
                    </VerticalStackLayout>
                </Frame>

                <!-- イベントリセット -->
                <Frame Padding="15" BorderColor="#E0E0E0" CornerRadius="8" HasShadow="False" BackgroundColor="White">
                    <VerticalStackLayout Spacing="10">
                        <Label Text="データ管理" FontSize="16" FontAttributes="Bold" TextColor="#333333" />
                        <Label Text="現在の参加情報をリセットします。" FontSize="12" TextColor="#888888" />
                        <Button Text="イベントリセット" 
                                Clicked="OnResetEventClicked" 
                                BackgroundColor="#F44336" 
                                TextColor="White" 
                                CornerRadius="8" 
                                HeightRequest="45"
                                Margin="0,10,0,0"/>
                    </VerticalStackLayout>
                </Frame>
            </VerticalStackLayout>
        </ScrollView>

        <!-- 組み合わせ設定ダイアログ（オーバーレイ） -->
        <Grid x:Name="MatchSettingsOverlay" BackgroundColor="#80000000" IsVisible="False">
            <Frame VerticalOptions="Center" HorizontalOptions="Center" WidthRequest="340" Padding="20" CornerRadius="12" BackgroundColor="White">
                <Grid RowDefinitions="Auto, Auto, Auto, Auto" RowSpacing="5">
                    <Label Grid.Row="0" Text="組み合わせ設定" FontSize="20" FontAttributes="Bold" HorizontalOptions="Center" TextColor="#333333" />
                    
                    <!-- <Label Grid.Row="1" Text="※チェック項目を上から優先します。&#10;項目をタップして順番を入れ替えられます。" 
                           FontSize="12" TextColor="#F44336" HorizontalOptions="Center" HorizontalTextAlignment="Center" Margin="0,5" /> -->

                    <CollectionView x:Name="SettingsCollectionView" 
                                    Grid.Row="2" 
                                    SelectionMode="None" 
                                    HeightRequest="300">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Frame Padding="12,10" Margin="0,4" BorderColor="#E0E0E0" CornerRadius="10" BackgroundColor="#F9F9F9" HasShadow="False">
                                    <Grid ColumnDefinitions="Auto, *">
                                        <CheckBox IsChecked="{Binding IsEnabled}" 
                                                  Grid.Column="0" 
                                                  VerticalOptions="Center" 
                                                  Color="#2196F3" />
                                        <Label Text="{Binding DisplayName}" 
                                               Grid.Column="1" 
                                               VerticalOptions="Center" 
                                               TextColor="#333333" 
                                               FontSize="15" 
                                               Margin="10,0,0,0">
                                            <Label.GestureRecognizers>
                                                <TapGestureRecognizer Tapped="OnSettingItemTapped" />
                                            </Label.GestureRecognizers>
                                        </Label>
                                    </Grid>
                                </Frame>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                    <VerticalStackLayout Grid.Row="3" Spacing="5" Margin="0,15,0,0">
                        <Button Text="保存して閉じる" Clicked="OnSaveMatchSettingsClicked" BackgroundColor="#4CAF50" TextColor="White" HeightRequest="45" CornerRadius="8" />
                        <Button Text="キャンセル" Clicked="OnCancelMatchSettingsClicked" BackgroundColor="Transparent" TextColor="#757575" />
                    </VerticalStackLayout>
                </Grid>
            </Frame>
        </Grid>
    </Grid>
</ContentPage>
